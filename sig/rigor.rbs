module Rigor
  VERSION: String

  class Configuration
    DEFAULT_PATH: String
    DEFAULTS: Hash[String, untyped]

    attr_reader target_ruby: String
    attr_reader paths: Array[String]
    attr_reader plugins: Array[String]
    attr_reader cache_path: String

    def self.load: (?String path) -> Configuration
    def initialize: (?Hash[String, untyped] data) -> void
    def to_h: () -> Hash[String, untyped]
  end

  class CLI
    EXIT_USAGE: Integer

    def self.start: (?Array[String] argv, ?out: untyped, ?err: untyped) -> Integer

    def initialize: (?Array[String] argv, ?out: untyped, ?err: untyped) -> void
    def run: () -> Integer

    class TypeOfCommand
      USAGE: String

      def initialize: (argv: Array[String], out: untyped, err: untyped) -> void
      def run: () -> Integer
    end

    class TypeScanCommand
      USAGE: String

      def initialize: (argv: Array[String], out: untyped, err: untyped) -> void
      def run: () -> Integer
    end
  end

  module Analysis
    class Diagnostic
      attr_reader path: String
      attr_reader line: Integer
      attr_reader column: Integer
      attr_reader message: String
      attr_reader severity: Symbol

      def initialize: (path: String, line: Integer, column: Integer, message: String, ?severity: Symbol) -> void
      def error?: () -> bool
      def to_h: () -> Hash[String, untyped]
      def to_s: () -> String
    end

    class Result
      attr_reader diagnostics: Array[Diagnostic]
      attr_reader stats: RunStats?

      def initialize: (?diagnostics: Array[Diagnostic], ?stats: RunStats?) -> void
      def success?: () -> bool
      def error_count: () -> Integer
      def to_h: () -> Hash[String, untyped]
    end

    class RunStats
      attr_reader wall_seconds: Float
      attr_reader peak_rss_bytes: Integer?
      attr_reader target_files: Integer
      attr_reader rbs_classes_total: Integer
      attr_reader rbs_classes_project_sig: Integer
      attr_reader rbs_classes_bundled: Integer
      attr_reader gem_walk_classes: Integer
      attr_reader gem_walk_gems: Integer
      attr_reader rbs_attribution_available: bool

      CACHED_SENTINEL: String

      def self.peak_rss_bytes: () -> Integer?
      def self.partition_classes: (class_decl_paths: Hash[String, String], signature_paths: Array[untyped]) -> [Integer, Integer]
      def self.attribution_available?: (class_decl_paths: Hash[String, String]) -> bool

      def initialize: (
        wall_seconds: Float,
        peak_rss_bytes: Integer?,
        target_files: Integer,
        rbs_classes_total: Integer,
        rbs_classes_project_sig: Integer,
        rbs_classes_bundled: Integer,
        gem_walk_classes: Integer,
        gem_walk_gems: Integer,
        ?rbs_attribution_available: bool
      ) -> void
      def format: (untyped out, ?prefix: String) -> void
      def to_h: () -> Hash[Symbol, untyped]
    end

    class Runner
      RUBY_GLOB: String
      DEFAULT_CACHE_ROOT: String
      # `Rigor::Cache::Store` itself is not yet sig-covered (the
      # cache namespace is in `UNSIGNED_NAMESPACES` per
      # `spec/rigor/public_api_drift_spec.rb`), so reference it as
      # `untyped` until the full Cache::Store sig lands. Steep
      # otherwise raises `RBS::UnknownTypeName` for the named type.
      attr_reader cache_store: untyped
      attr_reader plugin_registry: untyped
      attr_reader buffer: untyped
      def initialize: (configuration: Configuration, ?explain: bool, ?cache_store: untyped, ?plugin_requirer: untyped, ?workers: Integer, ?collect_stats: bool, ?buffer: untyped, ?prebuilt: untyped) -> void
      def run: (?Array[String] paths) -> Result
      def prepare_project_scan: (?paths: Array[String]) -> untyped
    end
  end
end
